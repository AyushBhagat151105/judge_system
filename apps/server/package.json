{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "test": "vitest run --passWithNoTests",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.js"
  },
  "dependencies": {
    "@judge_system/auth": "workspace:*",
    "@judge_system/db": "workspace:*",
    "@judge_system/env": "workspace:*",
    "@tanstack/ai": "^0.40.0",
    "@tanstack/ai-openai": "^0.16.0",
    "@tavily/core": "^0.7.6",
    "better-auth": "catalog:",
    "cors": "^2.8.6",
    "dotenv": "catalog:",
    "express": "^5.2.1",
    "winston": "^3.19.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@judge_system/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@vitest/coverage-v8": "catalog:",
    "@vitest/ui": "catalog:",
    "jsdom": "catalog:",
    "tsdown": "^0.22.3",
    "typescript": "catalog:",
    "unrun": "^0.3.1",
    "vitest": "catalog:"
  }
}
