# Server Environment Variables
# Copy this file to .env and fill in your values

# Database (Required)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/judge_system"

# Better Auth (Required)
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-super-secret-key-at-least-32-characters-long"

# Auth server URL (Required)
BETTER_AUTH_URL="http://localhost:3000"

# Frontend URL for CORS (Required)
CORS_ORIGIN="http://localhost:3001"

# Judge System API Key (Required)
# Used for internal API authentication
JUDGE_SYSTEM_API_KEY="sk-judge-system-dev-key-change-in-production"

# Tavily API Key (Required for AI features)
# Get from: https://tavily.com/
TAVILY_API_KEY="tvly-your-tavily-api-key-here"

# Google OAuth (Optional - enable for social login)
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Environment (Optional)
NODE_ENV="development"
